rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isValidId(id) { return id is string && id.size() <= 128; }

    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // User Data Guard: Users can only access their own documents
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /contacts/{contactId} {
        allow list, get: if isOwner(uid);
        allow create: if isOwner(uid) && request.resource.data.uid == uid;
        allow update, delete: if isOwner(uid);
      }

      match /tasks/{taskId} {
        allow list, get: if isOwner(uid);
        allow create: if isOwner(uid) && request.resource.data.uid == uid;
        allow update, delete: if isOwner(uid);
      }
    }
  }
}
